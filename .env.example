## AutoShotgun local configuration
##
## Copy this file to `.env` (same folder) and fill values.
## `.env` is ignored by git.

# Required: suffix used to build ShotGrid login from Deadline username.
# Example: if job.UserName is "hanna" and suffix is "@yourdomain.com",
# resulting login becomes "hanna@yourdomain.com".
AUTOSHOTGUN_LOGIN_SUFFIX=@millarc.com

# Required: default password for ShotGrid login.
# Example: if you want to use the same password for all users, you can set it here.
DEFAULT_PASSWORD=yourpassword